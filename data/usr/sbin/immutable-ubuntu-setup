#!/bin/bash
# /usr/sbin/immutable-ubuntu-setup
#
# Bootstrap script for the immutable Ubuntu system.
# Called from autoinstall late-commands after the immutable-ubuntu
# package is installed via the packages: section.
#
# Usage (from autoinstall late-commands):
#   /target/usr/sbin/immutable-ubuntu-setup --bootstrap [--repos URL,URL,...]
#
# This script runs in the INSTALLER environment (not inside the target
# chroot). It has access to /target and the raw block devices.

set -euo pipefail

# ── Self-relocate to /tmp ─────────────────────────────────────────────
# Phase 7 deletes top-level files from /target (including this script).
# Copy to /tmp so the running process isn't affected.
if [[ "${_IMMUTABLE_RELOCATED:-}" != "1" ]]; then
    cp "$0" /tmp/immutable-ubuntu-setup
    chmod +x /tmp/immutable-ubuntu-setup
    export _IMMUTABLE_RELOCATED=1
    exec /tmp/immutable-ubuntu-setup "$@"
fi

die()  { echo "FATAL: $*" >&2; exit 1; }
info() { echo "[immutable-setup] $*"; }

# ── Parse arguments ────────────────────────────────────────────────
BOOTSTRAP=0
REPOS_CSV=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --bootstrap) BOOTSTRAP=1 ;;
        --repos)     REPOS_CSV="$2"; shift ;;
        *)           die "unknown argument: $1" ;;
    esac
    shift
done

[[ $BOOTSTRAP -eq 1 ]] || die "usage: immutable-ubuntu-setup --bootstrap [--repos URL,URL,...]"

BTRFS_DEV="/dev/mapper/crypt-root"
T="/target/@"

# ══════════════════════════════════════════════════════════════════════
# Phase 1: Snapshot installed root into @ subvolume
# ══════════════════════════════════════════════════════════════════════
info "Phase 1: Snapshotting installed root into @"
btrfs subvolume snapshot /target /target/@

# ══════════════════════════════════════════════════════════════════════
# Phase 2: Create persistent subvolumes
# ══════════════════════════════════════════════════════════════════════
info "Phase 2: Creating persistent subvolumes"
for sv in @home @snapshots @log @apt-cache @tmp @spool @crash \
          @containers @flatpak @snap @libvirt @AccountsService \
          @gdm3 @bluetooth @cups @fwupd @netmanager @machine-id @swap; do
    btrfs subvolume show "/target/$sv" >/dev/null 2>&1 || \
        btrfs subvolume create "/target/$sv"
done

# ══════════════════════════════════════════════════════════════════════
# Phase 3: Migrate data from @ into persistent subvolumes
# ══════════════════════════════════════════════════════════════════════
info "Phase 3: Migrating data to persistent subvolumes"

migrate_sv() {
    local sv="$1" relpath="$2"
    local SRC="${T}${relpath}" DST="/target/$sv"
    mkdir -p "$SRC"
    if [ -d "$SRC" ] && [ "$(ls -A "$SRC" 2>/dev/null)" ]; then
        cp -a "$SRC"/. "$DST"/ 2>/dev/null || true
        rm -rf "${SRC:?}"/*
        info "  migrated: $relpath -> $sv"
    fi
}

migrate_sv @home        /home
migrate_sv @log         /var/log
migrate_sv @apt-cache   /var/cache/apt
migrate_sv @tmp         /tmp
migrate_sv @spool       /var/spool
migrate_sv @crash       /var/crash
migrate_sv @containers  /var/lib/docker
migrate_sv @flatpak     /var/lib/flatpak
migrate_sv @snap        /var/lib/snapd
migrate_sv @libvirt     /var/lib/libvirt
migrate_sv @AccountsService /var/lib/AccountsService
migrate_sv @gdm3        /var/lib/gdm3
migrate_sv @bluetooth   /var/lib/bluetooth
migrate_sv @cups        /var/lib/cups
migrate_sv @fwupd       /var/lib/fwupd
migrate_sv @netmanager  /etc/NetworkManager/system-connections

# Machine-id
[ -f "$T/etc/machine-id" ] && cp "$T/etc/machine-id" /target/@machine-id/machine-id

# Ensure mount points exist inside @
mkdir -p "$T/.snapshots"
mkdir -p "$T/swap"

# Swapfile (on persistent @swap subvolume, not inside @)
btrfs filesystem mkswapfile --size 4g "/target/@swap/swapfile"
info "  swapfile created: @swap/swapfile (4G)"

# ══════════════════════════════════════════════════════════════════════
# Phase 4: Generate /etc/fstab
# ══════════════════════════════════════════════════════════════════════
info "Phase 4: Generating fstab"

BTRFS_UUID=$(blkid -s UUID -o value "$BTRFS_DEV")
BOOT_DEV=$(lsblk -rno NAME,LABEL | awk '$2 == "BOOT" {print $1}')
BOOT_UUID=$(blkid -s UUID -o value "/dev/$BOOT_DEV")
EFI_DEV=$(lsblk -rno NAME,LABEL | awk '$2 == "EFI" {print $1}')
EFI_UUID=$(blkid -s UUID -o value "/dev/$EFI_DEV")
LUKS_PART=$(lsblk -rno NAME,FSTYPE | grep crypto_LUKS | head -1 | awk '{print $1}')
LUKS_UUID=$(blkid -s UUID -o value "/dev/$LUKS_PART")

BTRFS_OPTS="noatime,compress=zstd:1,space_cache=v2"

cat > "$T/etc/fstab" << FSTAB
# /etc/fstab — Immutable Ubuntu (auto-generated by immutable-ubuntu-setup)
#
# <filesystem>                          <mount>                                  <type>  <options>                                     <dump> <pass>

# --- EFI System Partition ---
UUID=${EFI_UUID}  /boot/efi  vfat  umask=0077  0  1

# --- /boot (unencrypted, outside LUKS) ---
UUID=${BOOT_UUID}  /boot  ext4  defaults  0  2

# --- btrfs subvolumes (inside LUKS) ---
# Root — THE snapshotted/rolled-back subvolume
UUID=${BTRFS_UUID}  /                                        btrfs  subvol=@,${BTRFS_OPTS}              0  0

# Persistent subvolumes — survive rollbacks
UUID=${BTRFS_UUID}  /home                                    btrfs  subvol=@home,${BTRFS_OPTS}          0  0
UUID=${BTRFS_UUID}  /.snapshots                              btrfs  subvol=@snapshots,${BTRFS_OPTS}     0  0
UUID=${BTRFS_UUID}  /var/log                                 btrfs  subvol=@log,${BTRFS_OPTS}           0  0
UUID=${BTRFS_UUID}  /var/cache/apt                           btrfs  subvol=@apt-cache,${BTRFS_OPTS}     0  0
UUID=${BTRFS_UUID}  /tmp                                     btrfs  subvol=@tmp,${BTRFS_OPTS}           0  0
UUID=${BTRFS_UUID}  /var/spool                               btrfs  subvol=@spool,${BTRFS_OPTS}         0  0
UUID=${BTRFS_UUID}  /var/crash                               btrfs  subvol=@crash,${BTRFS_OPTS}         0  0
UUID=${BTRFS_UUID}  /var/lib/docker                          btrfs  subvol=@containers,${BTRFS_OPTS}    0  0
UUID=${BTRFS_UUID}  /var/lib/flatpak                         btrfs  subvol=@flatpak,${BTRFS_OPTS}       0  0
UUID=${BTRFS_UUID}  /var/lib/snapd                           btrfs  subvol=@snap,${BTRFS_OPTS}          0  0
UUID=${BTRFS_UUID}  /var/lib/libvirt                         btrfs  subvol=@libvirt,${BTRFS_OPTS}       0  0
UUID=${BTRFS_UUID}  /var/lib/AccountsService                 btrfs  subvol=@AccountsService,${BTRFS_OPTS} 0 0
UUID=${BTRFS_UUID}  /var/lib/gdm3                            btrfs  subvol=@gdm3,${BTRFS_OPTS}          0  0
UUID=${BTRFS_UUID}  /var/lib/bluetooth                       btrfs  subvol=@bluetooth,${BTRFS_OPTS}     0  0
UUID=${BTRFS_UUID}  /var/lib/cups                            btrfs  subvol=@cups,${BTRFS_OPTS}          0  0
UUID=${BTRFS_UUID}  /var/lib/fwupd                           btrfs  subvol=@fwupd,${BTRFS_OPTS}         0  0
UUID=${BTRFS_UUID}  /etc/NetworkManager/system-connections   btrfs  subvol=@netmanager,${BTRFS_OPTS}    0  0
UUID=${BTRFS_UUID}  /swap                                    btrfs  subvol=@swap,${BTRFS_OPTS}            0  0

# --- Swap ---
/swap/swapfile  none  swap  defaults  0  0
FSTAB

# ══════════════════════════════════════════════════════════════════════
# Phase 5: Generate /etc/crypttab
# ══════════════════════════════════════════════════════════════════════
info "Phase 5: Generating crypttab"

cat > "$T/etc/crypttab" << CRYPTTAB
# <target name>  <source device>          <key file>  <options>
crypt-root        UUID=${LUKS_UUID}         none        luks,discard
CRYPTTAB

# ══════════════════════════════════════════════════════════════════════
# Phase 6: Enable machine-id persistence
# (service file installed by the deb package)
# ══════════════════════════════════════════════════════════════════════
info "Phase 6: Enabling machine-id persistence"
mkdir -p "$T/etc/systemd/system/sysinit.target.wants"
ln -sf /etc/systemd/system/machine-id-persist.service \
    "$T/etc/systemd/system/sysinit.target.wants/machine-id-persist.service"

# ══════════════════════════════════════════════════════════════════════
# Phase 7: Clean top-level btrfs (remove non-subvolume entries)
# ══════════════════════════════════════════════════════════════════════
info "Phase 7: Cleaning top-level btrfs"

umount /target/boot/efi 2>/dev/null || true
umount /target/boot     2>/dev/null || true

for item in /target/*; do
    base=$(basename "$item")
    case "$base" in
        @|@home|@snapshots|@log|@apt-cache|@tmp|@spool|@crash|\
        @containers|@flatpak|@snap|@libvirt|@AccountsService|\
        @gdm3|@bluetooth|@cups|@fwupd|@netmanager|@machine-id|@swap)
            continue ;;
        *)
            if mountpoint -q "$item" 2>/dev/null; then
                info "  skipping mount point: $base"
                continue
            fi
            rm -rf "$item" 2>/dev/null || true
            ;;
    esac
done

# ══════════════════════════════════════════════════════════════════════
# Phase 8: First-boot tweaks (baked into @ before snapshotting)
# ══════════════════════════════════════════════════════════════════════
info "Phase 8: Applying first-boot tweaks"

curtin in-target --target="$T" -- apt-get remove -y \
    gnome-initial-setup gnome-tour ubuntu-advantage-desktop-daemon 2>/dev/null || true
curtin in-target --target="$T" -- pro config set apt_news=false 2>/dev/null || true
curtin in-target --target="$T" -- systemctl mask systemd-networkd-wait-online.service
rm -f "$T/etc/cloud/cloud.cfg.d/90-installer-network.cfg"

# Generate SSH host keys
curtin in-target --target="$T" -- ssh-keygen -A

# Mark gnome-initial-setup as done for admin user
ADMIN_HOME="/target/@home/admin"
mkdir -p "$ADMIN_HOME/.config"
touch "$ADMIN_HOME/.config/gnome-initial-setup-done"

# Fix ownership
ADMIN_IDS=$(grep '^admin:' "$T/etc/passwd" | cut -d: -f3,4)
ADMIN_UID="${ADMIN_IDS%:*}"
ADMIN_GID="${ADMIN_IDS#*:}"
chown -R "${ADMIN_UID}:${ADMIN_GID}" "$ADMIN_HOME/.config"

# Seed cloud-init state so it doesn't re-run on every boot
mkdir -p "$T/var/lib/cloud/instance"
touch "$T/var/lib/cloud/instance/boot-finished"

# Write REPOS into immutable-update.conf
if [[ -n "$REPOS_CSV" ]]; then
    info "  configuring REPOS in immutable-update.conf"
    CONF="$T/etc/immutable-update.conf"
    # Replace the empty REPOS=() block with the provided URLs
    IFS=',' read -ra _repos <<< "$REPOS_CSV"
    {
        sed '/^REPOS=(/,/^)/d' "$CONF"
        echo 'REPOS=('
        for _url in "${_repos[@]}"; do
            echo "    \"${_url}\""
        done
        echo ')'
    } > "${CONF}.tmp"
    mv "${CONF}.tmp" "$CONF"
fi

# ══════════════════════════════════════════════════════════════════════
# Phase 9: Baseline snapshot
# ══════════════════════════════════════════════════════════════════════
info "Phase 9: Creating baseline snapshot"
TIMESTAMP=$(date +%Y%m%dT%H%M%S)
btrfs subvolume snapshot -r /target/@ "/target/@snapshots/root.$TIMESTAMP"

btrfs subvolume list /target | while read -r line; do
    info "  $line"
done

# ══════════════════════════════════════════════════════════════════════
# Phase 10: dracut + GRUB configuration
# ══════════════════════════════════════════════════════════════════════
info "Phase 10: Configuring dracut and GRUB"

# Set up cleanup trap for Phase 10 mounts
trap 'umount "$T/.snapshots" 2>/dev/null || true; umount "$T/boot/efi" 2>/dev/null || true; umount "$T/boot" 2>/dev/null || true; umount /target/@ 2>/dev/null || true' EXIT

mount -t btrfs -o subvol=@,noatime "$BTRFS_DEV" /target/@
mount -L BOOT "$T/boot"
mount -L EFI  "$T/boot/efi"
mount -t btrfs -o subvol=@snapshots,noatime "$BTRFS_DEV" "$T/.snapshots"

curtin in-target --target="$T" -- dracut --regenerate-all --force
chmod -x "$T/etc/grub.d/10_linux"
curtin in-target --target="$T" -- update-grub
curtin in-target --target="$T" -- grub-install \
    --target=x86_64-efi --efi-directory=/boot/efi \
    --bootloader-id=ubuntu --recheck

# Unmount Phase 10 mounts before Phase 11
umount "$T/.snapshots" 2>/dev/null || true
umount "$T/boot/efi"   2>/dev/null || true
umount "$T/boot"       2>/dev/null || true
umount /target/@       2>/dev/null || true

# Clear the trap (mounts already cleaned up)
trap - EXIT

# ══════════════════════════════════════════════════════════════════════
# Phase 11: Mount @log for installer shutdown
# ══════════════════════════════════════════════════════════════════════
info "Phase 11: Mounting @log for installer shutdown"
mkdir -p /target/var/log
mount -t btrfs -o subvol=@log,noatime "$BTRFS_DEV" /target/var/log
mkdir -p /target/var/log/installer

info "Bootstrap complete"
