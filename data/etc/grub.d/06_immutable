#!/bin/sh
# /etc/grub.d/06_immutable
#
# Generates GRUB menu entries for the immutable desktop:
#
#   1. "Immutable Desktop (clean)" — DEFAULT
#      Boots from the latest btrfs snapshot. An initramfs hook creates a
#      writable clone (@rootfs) from the read-only snapshot, then pivots
#      root to it. This discards any drift since the last snapshot.
#
#   2. "Immutable Desktop (tainted)"
#      Boots from @ directly, with the staging service masked.
#      Whatever is currently in @ — including out-of-band changes — is
#      what you get. Useful for debugging or manual intervention.
#
#   3. Per-snapshot entries (submenu)
#      One entry per historical snapshot, for booting a specific known-good
#      state. Same initramfs writable-clone mechanism as the default entry.
#
# This script is called by update-grub. It reads the snapshot directory
# and the current kernel to generate entries dynamically.

set -e

# --- Configuration ---
SNAPSHOT_DIR="/.snapshots"
BTRFS_DEVICE=$(findmnt -n -o SOURCE / | sed 's/\[.*\]//')
BTRFS_UUID=$(findmnt -n -o UUID /)
BOOT_UUID=$(findmnt -n -o UUID /boot)

# Find the LUKS UUID if applicable (for rd.luks.uuid= / rd.luks.name=)
CRYPT_UUID=""
DM_NAME=$(dmsetup info -c --noheadings -o name "$BTRFS_DEVICE" 2>/dev/null || true)
if [ -n "$DM_NAME" ]; then
    CRYPT_BACKING=$(cryptsetup status "$DM_NAME" 2>/dev/null | grep "device:" | awk '{print $2}')
    if [ -n "$CRYPT_BACKING" ]; then
        CRYPT_UUID=$(blkid -s UUID -o value "$CRYPT_BACKING" 2>/dev/null || true)
    fi
fi

# Current kernel and initrd
KERNEL_REL=$(ls /boot/vmlinuz-* 2>/dev/null | sed 's|.*/vmlinuz-||' | sort -V | tail -1)

if [ -z "$KERNEL_REL" ] || [ ! -f "/boot/initrd.img-${KERNEL_REL}" ]; then
    echo "Warning: No kernel or initrd found in /boot" >&2
    exit 0
fi

KERNEL_PATH="/vmlinuz-${KERNEL_REL}"
INITRD_PATH="/initrd.img-${KERNEL_REL}"

# Build the base kernel command line.
# Start from GRUB_CMDLINE_LINUX, add rootflags and crypto bits.
BASE_CMDLINE="${GRUB_CMDLINE_LINUX:-}"

# Add dracut LUKS parameters if encrypted
if [ -n "$CRYPT_UUID" ]; then
    echo "$BASE_CMDLINE" | grep -q "rd.luks.uuid=" || \
        BASE_CMDLINE="rd.luks.uuid=${CRYPT_UUID} rd.luks.name=${CRYPT_UUID}=${DM_NAME} ${BASE_CMDLINE}"
fi

# --- Helper to emit a menu entry ---
emit_entry() {
    TITLE="$1"
    SUBVOL="$2"
    IMMUTABLE="$3"        # "yes" to add rd.immutable (clean/snapshot boots)
    EXTRA_ARGS="$4"       # additional kernel params

    ROOTFLAGS="subvol=${SUBVOL}"

    # Build the full command line
    CMDLINE="root=UUID=${BTRFS_UUID} ro rootflags=${ROOTFLAGS} ${BASE_CMDLINE}"

    # rd.immutable triggers the dracut hook to create a writable clone
    if [ "$IMMUTABLE" = "yes" ]; then
        CMDLINE="${CMDLINE} rd.immutable"
    fi

    # Add any extra args (e.g., systemd.mask for tainted)
    if [ -n "$EXTRA_ARGS" ]; then
        CMDLINE="${CMDLINE} ${EXTRA_ARGS}"
    fi

    cat << ENTRY
menuentry '${TITLE}' --class ubuntu --class gnu-linux --class os {
    insmod gzio
    insmod part_gpt
    insmod btrfs

    search --no-floppy --fs-uuid --set=root ${BOOT_UUID}

    echo 'Loading kernel ${KERNEL_REL} ...'
    linux ${KERNEL_PATH} ${CMDLINE}
    echo 'Loading initrd ...'
    initrd ${INITRD_PATH}
}
ENTRY
}

# --- Find snapshots ---
SNAPSHOTS=""
if [ -d "$SNAPSHOT_DIR" ]; then
    SNAPSHOTS=$(find "$SNAPSHOT_DIR" -maxdepth 1 -name "root.*" -printf '%f\n' 2>/dev/null | sort -r)
fi

LATEST_SNAP=$(echo "$SNAPSHOTS" | head -1)

# ==========================================================================
# Entry 1: DEFAULT — Boot from latest snapshot (clean)
# ==========================================================================
if [ -n "$LATEST_SNAP" ]; then
    # Boot the snapshot. The initramfs hook will create a writable clone.
    # We point rootflags at the snapshot; the initramfs will pivot to @rootfs.
    emit_entry \
        "Immutable Desktop (clean — ${LATEST_SNAP})" \
        "@snapshots/${LATEST_SNAP}" \
        "yes" \
        ""
else
    # No snapshots yet — boot @ directly as fallback
    emit_entry \
        "Immutable Desktop (clean — no snapshots, using @)" \
        "@" \
        "yes" \
        ""
fi

# ==========================================================================
# Entry 2: Tainted — Boot from @ with staging service masked
# ==========================================================================
emit_entry \
    "Immutable Desktop (tainted — current root, skip rollback)" \
    "@" \
    "" \
    "systemd.mask=immutable-update.service systemd.mask=immutable-update.timer"

# ==========================================================================
# Submenu: All historical snapshots
# ==========================================================================
if [ -n "$SNAPSHOTS" ]; then
    echo "submenu 'Immutable Desktop — Snapshot History' --class ubuntu {"

    for snap in $SNAPSHOTS; do
        # Extract timestamp from snapshot name (root.YYYYMMDDTHHMMSS)
        TS=$(echo "$snap" | sed 's/root\.//')
        # Format for display: 2025-03-08 14:30:00
        DISPLAY_TS=$(echo "$TS" | sed 's/\(....\)\(..\)\(..\)T\(..\)\(..\)\(..\)/\1-\2-\3 \4:\5:\6/')

        emit_entry \
            "  Snapshot: ${DISPLAY_TS}" \
            "@snapshots/${snap}" \
            "yes" \
            ""
    done

    echo "}"
fi
